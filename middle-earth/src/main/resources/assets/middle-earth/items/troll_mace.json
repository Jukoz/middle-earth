{
  "model": {
    "type": "minecraft:condition",
    "on_false": {
      "type": "minecraft:select",
      "cases": [
        {
          "model": {
            "type": "minecraft:model",
            "model": "middle-earth:item/troll_mace_inventory"
          },
          "when": [
            "gui",
            "ground",
            "fixed"
          ]
        }
      ],
      "fallback": {
        "type": "minecraft:model",
        "model": "middle-earth:item/troll_mace"
      },
      "property": "minecraft:display_context"
    },
    "on_true": {
      "type": "minecraft:select",
      "cases": [
        {
          "model": {
            "type": "minecraft:model",
            "model": "middle-earth:item/troll_mace_broken_inventory"
          },
          "when": [
            "gui",
            "ground",
            "fixed"
          ]
        }
      ],
      "fallback": {
        "type": "minecraft:model",
        "model": "middle-earth:item/troll_mace_broken"
      },
      "property": "minecraft:display_context"
    },
    "property": "minecraft:broken"
  }
